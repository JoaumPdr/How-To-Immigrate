// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(uuid()) @db.Uuid
  name          String?
  email         String          @unique
  emailVerified DateTime?       @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]
  authenticator Authenticator[]
  profile       UserProfile?
  reviews       Review[]
  roadmaps      Roadmap[]
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  userId            String  @db.Uuid @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @db.Uuid @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @unique @map("credential_id")
  userId               String  @db.Uuid @map("user_id")
  providerAccountId    String  @map("provider_account_id")
  credentialPublicKey  String  @map("credential_public_key")
  counter              Int
  credentialDeviceType String  @map("credential_device_type")
  credentialBackedUp   Boolean @map("credential_backed_up")
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

model UserProfile {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @db.Uuid @map("user_id")
  age                  Int?
  nationality          String?
  education            String?
  profession           String?
  languages            String[]
  immigrationObjective String?  @map("immigration_objective")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Country {
  id           String             @id @default(uuid()) @db.Uuid
  slug         String             @unique
  name         String
  nameEn       String             @map("name_en")
  codeISO2     String             @unique @map("code_iso2")
  codeISO3     String             @unique @map("code_iso3")
  region       String
  capital      String
  currency     String
  languages    String[]
  flagUrl      String             @map("flag_url")
  overallScore Float              @map("overall_score")
  indicators   CountryIndicator[]
  reviews      Review[]
  articles     Article[]
  roadmaps     Roadmap[]
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@map("countries")
}

model CountryIndicator {
  id        String   @id @default(uuid()) @db.Uuid
  countryId String   @db.Uuid @map("country_id")
  category  String
  score     Float
  rawValue  Float    @map("raw_value")
  source    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, category])
  @@map("country_indicators")
}

model Review {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @db.Uuid @map("user_id")
  countryId   String                @db.Uuid @map("country_id")
  rating      Float
  content     String
  scores      ReviewCategoryScore[]
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  country     Country               @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model ReviewCategoryScore {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @db.Uuid @map("review_id")
  category  String
  score     Float
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, category])
  @@map("review_category_scores")
}

model ArticleCategory {
  id        String    @id @default(uuid()) @db.Uuid
  slug      String    @unique
  name      String
  articles  Article[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("article_categories")
}

model Article {
  id              String          @id @default(uuid()) @db.Uuid
  slug            String          @unique
  title           String
  summary         String
  content         String
  categoryId      String          @db.Uuid @map("category_id")
  countryId       String?         @db.Uuid @map("country_id")
  tags            String[]
  authorName      String          @map("author_name")
  readTimeMinutes Int             @map("read_time_minutes")
  publishedAt     DateTime        @map("published_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  category        ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  country         Country?        @relation(fields: [countryId], references: [id], onDelete: SetNull)

  @@map("articles")
}

model Roadmap {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @db.Uuid @map("user_id")
  countryId          String        @db.Uuid @map("country_id")
  progressPercentage Int           @map("progress_percentage")
  steps              RoadmapStep[]
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  country            Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@map("roadmaps")
}

model RoadmapStep {
  id           String   @id @default(uuid()) @db.Uuid
  roadmapId    String   @db.Uuid @map("roadmap_id")
  order        Int
  title        String
  description  String
  status       String
  visaType     String?  @map("visa_type")
  documents    String[]
  officialLink String?  @map("official_link")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  roadmap      Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([roadmapId, order])
  @@map("roadmap_steps")
}

model AffiliatePartner {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  logoUrl     String?  @map("logo_url")
  description String
  websiteUrl  String   @map("website_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("affiliate_partners")
}

